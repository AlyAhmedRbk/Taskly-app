{
  "name": "task-manager",
  "version": "1.0.0",
  "description": "Production-ready Task Manager with Node.js, Express, MySQL & Docker",
  "main": "server.js",
  "scripts": {
  "dev": "nodemon server.js",
  "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch",
  "build": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "mysql2": "^3.22.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4.2.2"
  }
}
